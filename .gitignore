# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Node / package managers ──────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-store/
.npm/

# ── Next.js ──────────────────────────────────────────────
.next/
out/
build/
next-env.d.ts
*.tsbuildinfo

# ── SmartCal runtime data ────────────────────────────────
# SQLite database, WAL, and journal live here by default.
# Never commit — contains events, chore history, Google OAuth tokens.
.data/
*.db
*.db-journal
*.db-wal
*.db-shm

# Screensaver photo library (if used locally)
/photos/

# Screenshot previews used during development
/.preview-*.png

# ── Environment / secrets ────────────────────────────────
.env
.env.*
!.env.example

# Google OAuth client secrets and tokens
credentials.json
token.json
service-account*.json

# ── Editors / OS ─────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ── Logs ─────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/

# ── Testing / coverage ───────────────────────────────────
coverage/
.nyc_output/

# ── Deploy ───────────────────────────────────────────────
.vercel/
*.pem
*.key

# ── Misc ─────────────────────────────────────────────────
.cache/
.tmp/
tmp/
